{
  "name": "typescript-simple-template",
  "version": "1.0.0",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "postinstall": "bunx cre-setup",
    "cre-compile": "bun build src/main.ts --outfile=dist/main.js --target=bun && (cp tmp.wasm src/tmp.wasm 2>/dev/null || true) #",
    "test": "bun test",
    "test:e2e": "bun test test/e2e",
    "demo": "CRE_CONFIG_PATH=config.demo.json bun run demo/main-demo.ts",
    "demo:simulate": "cre workflow simulate . -T demo-settings",
    "cre-demo-compile": "bun build demo/main-demo.ts --outfile=dist/demo-main.js --target=bun"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@chainlink/cre-sdk": "^1.0.3",
    "viem": "^2.45.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.21"
  }
}
